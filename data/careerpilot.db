      "id": "apt-4",
      "question": "A total budget of $1250 is shared among three departments A, B, and C in the ratio 2:3:5. What is the share of department B?",
      "category": "Quantitative",
      "subcategory": "Ratio & Proportion",
      "options": [
        "$355",
        "$425",
        "$385",
        "$375"
      ],
      "correctAnswer": "D",
      "explanation": "Sum of ratios = 2 + 3 + 5 = 10.\nShare of Department B = (Ratio of B / Sum of ratios) * Total Budget\nShare of B = (3 / 10) * $1250 = $375.",
      "difficulty": "Easy"
    },
    {
      "id": "apt-5",
      "question": "If Developer A can build a project in 18 days and Developer B can build the same project in 27 days, how many days will they take to complete it working together?",
      "category": "Quantitative",
      "subcategory": "Work & Time",
      "options": [
        "10.8 days",
        "12.3 days",
        "9.8 days",
        "14 days"
      ],
      "correctAnswer": "A",
      "explanation": "1 day work of A = 1 / 18\n1 day work of B = 1 / 27\nCombined 1 day work of A and B = (1 / 18) + (1 / 27) = (18 + 27) / (18 * 27) = 45 / 486.\nTotal days required = (18 * 27) / (18 + 27) = 486 / 45 = 10.8 days.",
      "difficulty": "Medium"
    },
