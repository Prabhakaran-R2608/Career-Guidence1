      "subcategory": "Percentage",
      "options": [
        "$345",
        "$305",
        "$320",
        "$340"
      ],
      "correctAnswer": "C",
      "explanation": "Discount amount = Original Price * (Discount Percentage / 100)\nDiscount = $400 * (20 / 100) = $80.\nSale Price = Original Price - Discount\nSale Price = $400 - $80 = $320.",
      "difficulty": "Hard"
    },
