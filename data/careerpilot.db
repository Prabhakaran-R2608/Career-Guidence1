    {
      "id": "apt-348",
      "question": "The present ages of A and B are in the ratio of 7:2. 7 years ago, the sum of their ages was 40 years. What is the present age of A?",
      "category": "Quantitative",
      "subcategory": "Ages",
      "options": [
        "38 years",
        "48 years",
        "42 years",
        "52 years"
      ],
      "correctAnswer": "C",
      "explanation": "Let the present ages of A and B be 7x and 2x.\nSum of present ages = 9x = 9x.\n7 years ago, the sum was 9x - (2 * 7) = 40.\n9x - 14 = 40\n9x = 54\nx = 6.\nPresent age of A = 7 * 6 = 42 years.",
      "difficulty": "Hard"
    },
