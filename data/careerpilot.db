    {
      "id": "apt-1",
      "question": "A train of length 100 meters crosses a utility pole in how many seconds if its constant speed is 36 km/hr?",
      "category": "Quantitative",
      "subcategory": "Time & Speed",
      "options": [
        "10 seconds",
        "12.5 seconds",
        "8.2 seconds",
        "15 seconds"
      ],
      "correctAnswer": "A",
      "explanation": "To calculate the crossing time, we convert the speed from km/hr to m/s:\nSpeed in m/s = Speed in km/hr * (5 / 18)\nSpeed = 36 * (5 / 18) = 10 m/s.\nTime taken = Train Length / Speed\nTime = 100 / 10 = 10 seconds.",
      "difficulty": "Easy"
    },
    {
      "id": "apt-2",
      "question": "The average age of a group of 11 students is 21 years. If a teacher of age 41 years joins the group, what is the new average age?",
      "category": "Quantitative",
      "subcategory": "Average",
      "options": [
        "21.17 years",
        "22.67 years",
        "23.87 years",
        "24.67 years"
      ],
      "correctAnswer": "B",
      "explanation": "Sum of ages of 11 students = 11 * 21 = 231 years.\nWith the teacher added, the total sum of ages = 231 + 41 = 272 years.\nTotal count of people = 11 + 1 = 12.\nNew Average Age = Total Sum / Total Count = 272 / 12 = 22.67 years.",
      "difficulty": "Medium"
    },
